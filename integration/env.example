# Copy to integration/.env (gitignored) and fill in for live LLM / services tests.
# merge-env script applies these into each generated fixture .env before runs.

# --- Live LLM (optional; mock mode does not require keys) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
AZURE_OPENAI_API_KEY=
AZURE_RESOURCE_NAME=

# Optional OpenAI-compatible proxy (generated OpenAI provider reads LLM_BASE_URL)
# LLM_BASE_URL=https://...

# --- Services (docker compose) ---
REDIS_URL=redis://127.0.0.1:16379
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:15432/agent

# --- RAG embeddings (pgvector path uses OpenAI embeddings by default) ---
EMBEDDING_MODEL=text-embedding-3-small
RAG_TOP_K=3

# --- Memory / sessions ---
AGENT_SESSION_ID=integration-test
