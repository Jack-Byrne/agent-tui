{
  "name": "agent-tui",
  "version": "0.1.0",
  "description": "Terminal TUI scaffolder for AI agent design patterns",
  "license": "MIT",
  "type": "module",
  "bin": {
    "agent-tui": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "INTEGRATION_QUICK=1 vitest run tests/integration --config vitest.integration.config.ts",
    "test:integration:all": "vitest run tests/integration --config vitest.integration.config.ts",
    "integration:generate": "tsx integration/generate-fixtures.ts",
    "integration:run": "tsx integration/run.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "commander": "^13.1.0",
    "fs-extra": "^11.3.0",
    "handlebars": "^4.7.8",
    "ink": "^5.2.0",
    "ink-select-input": "^6.0.0",
    "ink-text-input": "^6.0.0",
    "pathe": "^2.0.3",
    "react": "^18.3.1",
    "zod": "^3.24.2",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^22.13.10",
    "@types/react": "^18.3.18",
    "ioredis": "^5.4.2",
    "pg": "^8.14.1",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.0.8"
  }
}
