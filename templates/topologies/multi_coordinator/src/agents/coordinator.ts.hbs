import { generateText } from "ai";
import { createLanguageModel, llmDefaults } from "../llm/create-model.js";
import { systemPrompt } from "../prompts/prompts.js";
import {
  appendAssistant,
  appendUser,
  loadSession,
  persistSession,
} from "../memory/memory.js";
import * as searchWorker from "./workers/search.js";
import * as calcWorker from "./workers/calc.js";
import * as writeWorker from "./workers/write.js";

/**
 * Coordinator / hierarchical decomposition stub.
 * Replace `classify` with structured routing (LLM or rules).
 * @see {{patternDocUrl}}
 */
async function classify(task: string): Promise<"search" | "calc" | "write"> {
  const model = createLanguageModel();
  const { text } = await generateText({
    model,
    temperature: 0,
    maxTokens: 32,
    system: `${systemPrompt}\n\nReturn exactly one token: search | calc | write`,
    prompt: `Task: ${task}`,
  });
  const token = text.trim().toLowerCase();
  if (token.includes("calc")) return "calc";
  if (token.includes("write")) return "write";
  return "search";
}

export async function runCoordinator(userInput: string): Promise<string> {
  const session = await loadSession();
  appendUser(session, userInput);
  const route = await classify(userInput);
  let out: string;
  if (route === "calc") out = await calcWorker.calcWorker(userInput);
  else if (route === "write") out = await writeWorker.writeWorker(userInput);
  else {
    const researched = await searchWorker.searchWorker(userInput);
    out = await writeWorker.writeWorker(`Synthesize for user.\n${researched}`);
  }
  appendAssistant(session, out);
  await persistSession(session);
  return out;
}
