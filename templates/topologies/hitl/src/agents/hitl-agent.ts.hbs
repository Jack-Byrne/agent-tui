export async function runHitlAgent(userInput: string): Promise<string> {
  const model = createLanguageModel();
  const tools = getTools();
  const toolMap = Object.keys(tools).length ? tools : undefined;
  const hasTools = Boolean(toolMap);

  const session = await loadSession();
  appendUser(session, userInput);
  const messages = messagesForModel(session);

  const draft = await generateText({
    model,
    temperature: llmDefaults.temperature,
    maxTokens: llmDefaults.maxTokens,
    system: `${systemPrompt}\n\nProduce a draft; a human must approve before execution.`,
    messages,
    tools: toolMap,
    maxSteps: hitlMaxSteps(hasTools),
  });

  appendAssistant(session, draft.text);
  await persistSession(session);

  if (process.env.SKIP_HITL === "true") {
    return draft.text;
  }

  return `${draft.text}\n\n[HitL checkpoint: require human approval before acting on tools in production]`;
}
