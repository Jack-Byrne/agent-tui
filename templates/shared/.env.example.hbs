# LLM (see agent.scaffold.json for provider)
{{{llm.apiKeyEnvVar}}}=your-key-here
{{#if llm.baseUrl}}
# Optional base URL (e.g. Ollama or proxy)
LLM_BASE_URL={{{llm.baseUrl}}}
{{/if}}
# Integration / memory (optional)
AGENT_SESSION_ID=default
{{#if (eq memory "file")}}
MEMORY_FILE_PATH=data/memory-session.json
{{/if}}
{{#if (eq memory "redis")}}
REDIS_URL=redis://127.0.0.1:6379
{{/if}}
# Offline LLM stub (agent-tui integration)
# AGENT_TUI_MOCK_LLM=1
# AGENT_TUI_MOCK_SCENARIO=default
# AGENT_TUI_MOCK_TEXT=MOCK_OK
{{#if (eq knowledge "vector_db")}}{{#if (eq vectorBackend "pgvector")}}
# Embeddings for pgvector RAG (OpenAI-compatible key)
OPENAI_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
RAG_TOP_K=3
{{/if}}{{/if}}
{{#if useSqlDatabase}}
{{#if (eq sqlBootstrap "sqlite_file")}}
# Relative path is under the project root unless SQLITE_PATH is absolute
SQLITE_PATH={{{sqliteFilePath}}}
{{else}}
{{{databaseUrlEnvVar}}}={{#if (eq sqlBootstrap "docker_postgres")}}postgres://postgres:postgres@localhost:5432/agent{{else}}postgres://user:pass@localhost:5432/dbname{{/if}}
{{/if}}
{{/if}}
